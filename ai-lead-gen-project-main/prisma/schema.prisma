// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DATABASE_DIRECT_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  SALES
  USER
}

enum AuditAction {
  LOGIN
  LOGOUT
  REGISTER
  PASSWORD_CHANGE
  PASSWORD_RESET
  OAUTH_LOGIN
  ACCOUNT_LINK
  PROFILE_UPDATE
  ROLE_CHANGE
  DELETE_ACCOUNT
  SESSION_REFRESH
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  LOST
}

enum LeadActivityType {
  CREATED
  UPDATED
  STATUS_CHANGED
  TAG_ADDED
  TAG_REMOVED
  NOTE_ADDED
}

model User {
  id                    String          @id @default(cuid())
  firstName             String
  lastName              String
  email                 String          @unique
  passwordHash          String?
  role                  UserRole        @default(USER)
  image                 String?
  isActive              Boolean         @default(true)
  emailVerified         DateTime?
  twoFactorEnabled      Boolean         @default(false)
  twoFactorSecret       String?
  lastLoginAt           DateTime?
  lastLoginIp           String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  // Relations
  accounts              Account[]
  sessions              Session[]
  refreshTokens         RefreshToken[]
  verificationTokens    VerificationToken[]
  auditLogs             AuditLog[]
  leads                 Lead[]
  leadTags              LeadTag[]
  aiGenerations         AIGeneration[]
  aiUsage               AIUsage?

  // Module 4: Campaigns & Workflows
  campaigns             Campaign[]      @relation("UserCampaigns")
  workflows             Workflow[]      @relation("UserWorkflows")

  // Module 5: Content
  contents              Content[]       @relation("UserContents")

  // Module 6: Scheduling
  scheduledContents     ScheduledContent[] @relation("UserScheduledContents")

  // Module 7: Conversations
  conversations         Conversation[]  @relation("UserConversations")

  // Module 8: Integrations
  integrations          Integration[]   @relation("UserIntegrations")

  // Module 9: Analytics
  analytics             Analytics[]     @relation("UserAnalytics")
  notifications         Notification[]  @relation("UserNotifications")

  @@index([email])
  @@index([role])
}

model Account {
  id                    String          @id @default(cuid())
  userId                String
  user                  User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  type                  String
  provider              String
  providerAccountId     String
  refreshToken          String?
  accessToken           String?
  expiresAt             Int?
  tokenType             String?
  scope                 String?
  idToken               String?

  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id                    String          @id @default(cuid())
  sessionToken          String          @unique
  userId                String
  user                  User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  userAgent             String?
  ipAddress             String?
  expiresAt             DateTime
  rememberMe            Boolean         @default(false)

  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  @@index([userId])
  @@index([expiresAt])
}

model RefreshToken {
  id                    String          @id @default(cuid())
  userId                String
  user                  User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  token                 String          @unique
  expiresAt             DateTime
  revokedAt             DateTime?

  createdAt             DateTime        @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model VerificationToken {
  id                    String          @id @default(cuid())
  userId                String
  user                  User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  token                 String          @unique
  type                  String          // 'email-verification' or 'password-reset'
  expiresAt             DateTime
  usedAt                DateTime?

  createdAt             DateTime        @default(now())

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

model AuditLog {
  id                    String          @id @default(cuid())
  userId                String?
  user                  User?           @relation(fields: [userId], references: [id], onDelete: SetNull)

  action                AuditAction
  entityType            String
  entityId              String?
  oldValue              String?
  newValue              String?
  ipAddress             String?
  userAgent             String?
  metadata              String?

  createdAt             DateTime        @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model FailedLoginAttempt {
  id                    String          @id @default(cuid())
  email                 String?
  ipAddress             String
  attemptCount          Int             @default(1)
  lastAttemptAt         DateTime        @updatedAt
  lockedUntil           DateTime?

  @@unique([email, ipAddress])
  @@index([ipAddress])
  @@index([email])
  @@index([lockedUntil])
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)

  type        String   // NEW_LEAD, POST_PUBLISHED, POST_FAILED, INTEGRATION, SYSTEM
  title       String
  body        String?  @db.Text
  link        String?
  read        Boolean  @default(false)
  readAt      DateTime?
  metadata    Json?

  createdAt   DateTime @default(now())

  @@index([userId, read])
  @@index([createdAt])
}

model Lead {
  id                    String          @id @default(cuid())
  userId                String
  user                  User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  firstName             String
  lastName              String
  email                 String
  phone                 String?
  company               String?
  jobTitle              String?
  linkedinUrl           String?
  instagramHandle       String?
  source                String?
  externalId            String?
  status                LeadStatus      @default(NEW)
  score                 Int             @default(0)
  notes                 String?

  tags                  LeadTag[]       @relation("LeadToTag")
  activities            LeadActivity[]
  statusHistory         LeadStatusHistory[]
  aiGenerations         AIGeneration[]

  // Module 4: Campaigns
  campaigns             CampaignLead[]

  // Module 6: Scheduling
  scheduledMessages     ScheduledMessage[]

  // Module 7: Conversations
  conversations         Conversation[]

  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  @@index([userId])
  @@index([status])
  @@index([email])
  @@index([company])
  @@index([createdAt])
}

model LeadTag {
  id                    String          @id @default(cuid())
  userId                String
  user                  User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  name                  String
  color                 String          @default("#000000")
  leads                 Lead[]          @relation("LeadToTag")

  createdAt             DateTime        @default(now())

  @@unique([userId, name])
  @@index([userId])
}

model LeadActivity {
  id                    String          @id @default(cuid())
  leadId                String
  lead                  Lead            @relation(fields: [leadId], references: [id], onDelete: Cascade)

  activityType          LeadActivityType
  description           String?

  createdAt             DateTime        @default(now())

  @@index([leadId])
  @@index([createdAt])
}

model LeadStatusHistory {
  id                    String          @id @default(cuid())
  leadId                String
  lead                  Lead            @relation(fields: [leadId], references: [id], onDelete: Cascade)

  oldStatus             LeadStatus
  newStatus             LeadStatus

  createdAt             DateTime        @default(now())

  @@index([leadId])
  @@index([createdAt])
}

// MODULE 3: AI PERSONALIZATION ENGINE

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  SENT
}

enum AIMessageType {
  CONNECTION_MESSAGE
  FOLLOWUP_MESSAGE
  SALES_PITCH
  COLD_OUTREACH
  CALL_INVITATION
  REENGAGEMENT
}

enum MessageTone {
  PROFESSIONAL
  FRIENDLY
  CONSULTATIVE
  DIRECT
  EXECUTIVE
}

enum MessageLength {
  SHORT
  MEDIUM
  LONG
}

model AIGeneration {
  id                    String          @id @default(cuid())
  userId                String
  user                  User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  leadId                String
  lead                  Lead            @relation(fields: [leadId], references: [id], onDelete: Cascade)

  messageType           AIMessageType
  tone                  MessageTone
  length                MessageLength

  prompt                String          @db.Text
  response              String          @db.Text

  tokensUsed            Int             @default(0)
  provider              String          @default("openai") // openai, openrouter

  // Approval workflow
  approvalStatus        ApprovalStatus  @default(PENDING)
  approvedMessage       String?         @db.Text  // edited version if user modified before approving
  approvedAt            DateTime?
  rejectedAt            DateTime?
  rejectionReason       String?

  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  @@index([userId])
  @@index([leadId])
  @@index([messageType])
  @@index([approvalStatus])
  @@index([createdAt])
}

model AIUsage {
  id                    String          @id @default(cuid())
  userId                String          @unique
  user                  User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  dailyTokensUsed       Int             @default(0)
  monthlyTokensUsed     Int             @default(0)
  generationsToday      Int             @default(0)
  generationsThisMonth  Int             @default(0)

  dailyLimitResetAt     DateTime
  monthlyLimitResetAt   DateTime

  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  @@index([userId])
}

// MODULE 4: OUTREACH WORKFLOW ENGINE

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum WorkflowStepType {
  MESSAGE
  DELAY
  CONDITION
  BRANCH
}

enum CampaignLeadStatus {
  PENDING
  SENT
  OPENED
  REPLIED
  FAILED
  SKIPPED
}

model Campaign {
  id                    String          @id @default(cuid())
  userId                String
  user                  User            @relation("UserCampaigns", fields: [userId], references: [id], onDelete: Cascade)

  name                  String
  description           String?
  status                CampaignStatus  @default(DRAFT)
  leadCount             Int             @default(0)
  sentCount             Int             @default(0)
  openCount             Int             @default(0)
  replyCount            Int             @default(0)

  workflowId            String?
  workflow              Workflow?       @relation("CampaignWorkflow", fields: [workflowId], references: [id], onDelete: SetNull)

  leads                 CampaignLead[]
  activities            CampaignActivity[]

  startDate             DateTime?
  endDate               DateTime?
  startedAt             DateTime?
  launchedAt            DateTime?
  completedAt           DateTime?
  settings              Json?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

enum WorkflowExecutionStatus {
  RUNNING
  PAUSED
  COMPLETED
  FAILED
  CANCELLED
}

model WorkflowExecution {
  id                    String                  @id @default(cuid())
  workflowId            String
  campaignId            String
  leadId                String

  status                WorkflowExecutionStatus @default(RUNNING)
  currentStep           Int                     @default(0)
  nextRunAt             DateTime?               // when the next step should run (durable delays)
  startedAt             DateTime                @default(now())
  completedAt           DateTime?
  error                 String?                 @db.Text

  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt

  @@index([workflowId])
  @@index([campaignId])
  @@index([leadId])
  @@index([status])
  @@index([nextRunAt])
}

model CampaignLead {
  id                    String          @id @default(cuid())
  campaignId            String
  campaign              Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  leadId                String
  lead                  Lead            @relation(fields: [leadId], references: [id], onDelete: Cascade)

  status                CampaignLeadStatus @default(PENDING)
  sentAt                DateTime?
  openedAt              DateTime?
  repliedAt             DateTime?
  failureReason         String?

  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  @@unique([campaignId, leadId])
  @@index([campaignId])
  @@index([leadId])
  @@index([status])
}

model CampaignActivity {
  id                    String          @id @default(cuid())
  campaignId            String
  campaign              Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  action                String          // 'created', 'sent', 'opened', 'replied', 'failed', 'status_changed'
  description           String?
  metadata              String?         @db.Text

  createdAt             DateTime        @default(now())

  @@index([campaignId])
  @@index([createdAt])
}

model Workflow {
  id                    String          @id @default(cuid())
  userId                String
  user                  User            @relation("UserWorkflows", fields: [userId], references: [id], onDelete: Cascade)

  name                  String
  description           String?
  isActive              Boolean         @default(true)

  steps                 WorkflowStep[]
  campaigns             Campaign[]      @relation("CampaignWorkflow")

  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  @@index([userId])
  @@index([isActive])
}

model WorkflowStep {
  id                    String          @id @default(cuid())
  workflowId            String
  workflow              Workflow        @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  stepNumber            Int
  type                  WorkflowStepType
  delayMinutes          Int?            // For delay steps
  messageTemplate       String?         @db.Text // For message steps
  condition             String?         @db.Text // For condition steps

  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  @@unique([workflowId, stepNumber])
  @@index([workflowId])
}

model ScheduledMessage {
  id                    String          @id @default(cuid())
  campaignLeadId        String

  leadId                String
  lead                  Lead            @relation(fields: [leadId], references: [id], onDelete: Cascade)

  messageContent        String          @db.Text
  scheduledFor          DateTime
  sentAt                DateTime?
  failureReason         String?

  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  @@index([leadId])
  @@index([scheduledFor])
  @@index([sentAt])
}

// MODULE 5: CONTENT CREATION

enum ContentType {
  LINKEDIN_POST
  INSTAGRAM_CAPTION
  POSTER
  VIDEO_SCRIPT
  JOB_POST
  COMPANY_ANNOUNCEMENT
}

model Content {
  id                    String          @id @default(cuid())
  userId                String
  user                  User            @relation("UserContents", fields: [userId], references: [id], onDelete: Cascade)

  type                  ContentType
  title                 String
  body                  String          @db.Text
  aiGenerated           Boolean         @default(false)

  // Lifecycle (draft -> approved -> published, or rejected)
  status                String          @default("DRAFT")
  approvedBy            String?
  approvedAt            DateTime?
  publishedAt           DateTime?
  publishedOn           String?
  rejectedBy            String?
  rejectedAt            DateTime?
  rejectionReason       String?

  versions              ContentVersion[]
  scheduledContents     ScheduledContent[]

  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
}

model ContentVersion {
  id                    String          @id @default(cuid())
  contentId             String
  content               Content         @relation(fields: [contentId], references: [id], onDelete: Cascade)

  versionNumber         Int
  body                  String          @db.Text
  changeNotes           String?
  createdBy             String?

  createdAt             DateTime        @default(now())

  @@unique([contentId, versionNumber])
  @@index([contentId])
}

// MODULE 6: CONTENT SCHEDULING

enum PublishingStatus {
  DRAFT
  PENDING
  SCHEDULED
  PUBLISHING
  PUBLISHED
  CANCELLED
  FAILED
}

model ScheduledContent {
  id                    String          @id @default(cuid())
  userId                String
  user                  User            @relation("UserScheduledContents", fields: [userId], references: [id], onDelete: Cascade)

  contentId             String?
  content               Content?        @relation(fields: [contentId], references: [id], onDelete: SetNull)

  title                 String
  body                  String          @db.Text
  status                PublishingStatus @default(DRAFT)

  scheduledFor          DateTime?
  publishedAt           DateTime?
  cancelledAt           DateTime?
  failedAt              DateTime?
  failureReason         String?
  metadata              Json?

  platform              String          // 'linkedin', 'instagram'
  timezone              String          @default("UTC")

  // Approval workflow
  requiresApproval      Boolean         @default(false)
  approvalStatus        ApprovalStatus  @default(PENDING)
  approvedAt            DateTime?
  rejectedAt            DateTime?
  approvalNotes         String?

  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  @@index([userId])
  @@index([status])
  @@index([approvalStatus])
  @@index([scheduledFor])
  @@index([createdAt])
}

model PublishingQueue {
  id                    String          @id @default(cuid())
  scheduledContentId    String

  platform              String
  status                String          @default("pending") // pending, processing, published, failed

  attemptCount          Int             @default(0)
  lastAttemptAt         DateTime?
  nextRetryAt           DateTime?
  errorMessage          String?

  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  @@index([status])
  @@index([scheduledContentId])
  @@index([nextRetryAt])
}

// MODULE 7: CONVERSATION ASSISTANT

model Conversation {
  id                    String          @id @default(cuid())
  userId                String
  user                  User            @relation("UserConversations", fields: [userId], references: [id], onDelete: Cascade)

  leadId                String
  lead                  Lead            @relation(fields: [leadId], references: [id], onDelete: Cascade)

  subject               String?
  platform              String          @default("email")
  unreadCount           Int             @default(0)
  lastMessageAt         DateTime        @default(now())
  messages              ConversationMessage[]

  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  @@index([userId])
  @@index([platform])
  @@index([leadId])
  @@index([createdAt])
  @@index([lastMessageAt])
}

model ConversationMessage {
  id                    String          @id @default(cuid())
  conversationId        String
  conversation          Conversation    @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  sender                String          // 'user' or 'lead'
  content               String          @db.Text
  isAiSuggested         Boolean         @default(false)

  createdAt             DateTime        @default(now())

  @@index([conversationId])
  @@index([createdAt])
}

// MODULE 8: SOCIAL INTEGRATIONS

enum IntegrationProvider {
  LINKEDIN
  INSTAGRAM
  GOOGLE
}

enum IntegrationStatus {
  ACTIVE
  INACTIVE
  EXPIRED
}

model Integration {
  id                    String          @id @default(cuid())
  userId                String
  user                  User            @relation("UserIntegrations", fields: [userId], references: [id], onDelete: Cascade)

  provider              IntegrationProvider
  status                IntegrationStatus @default(INACTIVE)
  profileName           String?
  profileUrl            String?

  tokens                IntegrationToken[]
  webhookEvents         WebhookEvent[]

  connectedAt           DateTime?
  disconnectedAt        DateTime?
  lastSyncAt            DateTime?

  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  @@unique([userId, provider])
  @@index([userId])
  @@index([provider])
  @@index([status])
}

model IntegrationToken {
  id                    String          @id @default(cuid())
  integrationId         String
  integration           Integration     @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  accessToken           String
  refreshToken          String?
  expiresAt             DateTime?
  scope                 String?

  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  @@index([integrationId])
  @@index([expiresAt])
}

model WebhookEvent {
  id                    String          @id @default(cuid())
  integrationId         String
  integration           Integration     @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  eventType             String
  payload               String          @db.Text
  processed             Boolean         @default(false)
  processedAt           DateTime?

  createdAt             DateTime        @default(now())

  @@index([integrationId])
  @@index([eventType])
  @@index([processed])
}

// MODULE 9: CRM & ANALYTICS

model Analytics {
  id                    String          @id @default(cuid())
  userId                String
  user                  User            @relation("UserAnalytics", fields: [userId], references: [id], onDelete: Cascade)

  date                  DateTime

  totalLeads            Int             @default(0)
  newLeads              Int             @default(0)
  contactedLeads        Int             @default(0)
  qualifiedLeads        Int             @default(0)
  convertedLeads        Int             @default(0)

  conversionRate        Float           @default(0.0)
  campaignsRun          Int             @default(0)
  messagesGenerated     Int             @default(0)
  tokensUsed            Int             @default(0)

  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}


/// Host-agnostic distributed rate limiting (works on serverless + Neon; replaces the
/// in-memory Map which does not hold across instances). One row per (key, window).
model RateLimitCounter {
  id        String   @id @default(cuid())
  key       String   @unique
  count     Int      @default(0)
  resetAt   DateTime

  @@index([resetAt])
}
