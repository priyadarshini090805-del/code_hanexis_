    "clsx": "^2.0.0",
    "cookie": "^0.6.0",
    "csv-parser": "^3.0.0",
    "framer-motion": "^12.42.0",
    "jose": "^5.2.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.525.0",
    "next": "^15.0.0",
