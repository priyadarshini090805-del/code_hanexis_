    "nodemailer": "^7.0.13",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^3.0.0",
    "tailwind-merge": "^2.2.0",
    "three": "^0.185.0",
    "xlsx": "^0.18.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^16.0.0",
    "@types/cookie": "^0.6.0",
    "@types/jest": "^29.5.11",
