# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/hanexes

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================
# Generate: openssl rand -base64 32
JWT_SECRET=your-secret-key-min-32-chars-here
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars-here
PASSWORD_SALT=your-password-salt

# Generate: openssl rand -hex 16
ENCRYPTION_KEY=your-encryption-key-min-32-chars

# =============================================================================
# GOOGLE OAUTH
# =============================================================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# =============================================================================
# LINKEDIN OAUTH
# =============================================================================
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_WEBHOOK_SECRET=your-webhook-secret

# =============================================================================
# INSTAGRAM OAUTH
# =============================================================================
INSTAGRAM_CLIENT_ID=your-instagram-client-id
INSTAGRAM_CLIENT_SECRET=your-instagram-client-secret
INSTAGRAM_WEBHOOK_SECRET=your-webhook-secret

# =============================================================================
# AI PROVIDERS
# =============================================================================
OPENROUTER_API_KEY=your-openrouter-api-key
OPENAI_API_KEY=your-openai-api-key

# =============================================================================
# EMAIL (SMTP or SendGrid)
# =============================================================================
# SendGrid
SENDGRID_API_KEY=your-sendgrid-api-key

# SMTP Alternative
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@hanexes.com

# =============================================================================
# SMS & WHATSAPP (Twilio)
# =============================================================================
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_NUMBER=+1234567890

# =============================================================================
# REDIS & QUEUE
# =============================================================================
REDIS_URL=redis://localhost:6379

# =============================================================================
# LEAD ENRICHMENT APIs
# =============================================================================
HUNTER_API_KEY=your-hunter-api-key
CLEARBIT_API_KEY=your-clearbit-api-key
ENRICHMENT_API_KEY=your-enrichment-api-key

# =============================================================================
# ERROR TRACKING (Sentry)
# =============================================================================
SENTRY_DSN=https://key@sentry.io/project-id

# =============================================================================
# APP CONFIGURATION
# =============================================================================
APP_URL=http://localhost:3000
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================================
# WEBHOOKS
# =============================================================================
WEBHOOK_SECRET=your-webhook-secret
WEBHOOK_TIMEOUT=30000

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX_REQUESTS=100

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=info
LOG_FORMAT=json

# =============================================================================
# MONITORING
# =============================================================================
ENABLE_MONITORING=true
DATADOG_API_KEY=
NEW_RELIC_LICENSE_KEY=
