# ============================================================================
# HaneXes — Production environment template
# Copy to .env (local) or set each as a Vercel Environment Variable.
# ⚠️  ROTATE every secret that was ever shared in plaintext before going live.
# ============================================================================

# --- Database (Neon Postgres) ---
# Pooled URL for the app, direct URL for migrations (Prisma needs both).
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require"
DATABASE_DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/neondb?sslmode=require"

# --- App URL (must be the deployed https origin; used for OAuth redirects) ---
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"
NEXTAUTH_URL="https://your-app.vercel.app"

# --- Auth secrets (generate fresh: `openssl rand -hex 32`) ---
NEXTAUTH_SECRET="REPLACE_WITH_FRESH_32B_HEX"
JWT_SECRET="REPLACE_WITH_DIFFERENT_FRESH_32B_HEX"
JWT_REFRESH_SECRET="REPLACE_WITH_ANOTHER_FRESH_32B_HEX"

# --- Token encryption (must be >= 32 chars; only first 32 used as AES-256 key) ---
ENCRYPTION_KEY="REPLACE_WITH_FRESH_32+_CHAR_STRING"

# --- AI (OpenRouter) ---
OPENROUTER_API_KEY="REPLACE_ROTATED_OPENROUTER_KEY"
OPENROUTER_MODEL="meta-llama/llama-3.3-70b-instruct"
# Optional: OPENAI_API_KEY="" (the OpenAI provider is a fallback path)

# --- Google OAuth (Gmail lead-capture + Google login) ---
GOOGLE_CLIENT_ID="REPLACE"
GOOGLE_CLIENT_SECRET="REPLACE"

# --- LinkedIn OAuth (profile + post publishing; needs "Share on LinkedIn" product) ---
LINKEDIN_CLIENT_ID="REPLACE"
LINKEDIN_CLIENT_SECRET="REPLACE"

# --- Instagram (Business account; "Instagram API with Instagram Login") ---
FEATURE_INSTAGRAM_ENABLED="true"
INSTAGRAM_CLIENT_ID="REPLACE"
INSTAGRAM_CLIENT_SECRET="REPLACE"
INSTAGRAM_WEBHOOK_TOKEN="REPLACE_WEBHOOK_VERIFY_TOKEN"

# --- Email (Resend; for password reset / verification) ---
RESEND_API_KEY="REPLACE"
EMAIL_FROM="noreply@yourdomain.com"

# --- Cron protection (Vercel sends this as a Bearer header to /api/cron/*) ---
CRON_SECRET="REPLACE_FRESH_RANDOM"

# --- Misc ---
LOG_LEVEL="info"
# REDIS_URL is NOT required: this build uses a Postgres-backed queue + Vercel Cron
# and a Postgres-backed rate limiter. Leave Redis out unless you re-introduce BullMQ.
